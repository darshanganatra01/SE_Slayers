// ─────────────────────────────────────────────
//  Hardware Store Operations — ER Diagram
// ─────────────────────────────────────────────


// ══════════════════════════════════════════════
//  AUTH
// ══════════════════════════════════════════════

Table User {
  UID        varchar [pk]
  FullName   varchar [not null]
  Role       varchar [not null, note: 'Admin / Manager / Sales / Store']
  Email      varchar [unique, not null]
  PasswordHash varchar [not null]
  IsActive   boolean [default: true]

  Note: 'Staff accounts. UID is used as CreatedBy / RecordedBy / AdjustedBy / InitiatedBy / DispatchedBy across all operational tables.'
}


// ══════════════════════════════════════════════
//  CATALOG & INVENTORY
// ══════════════════════════════════════════════

Table Product {
  PID             varchar [pk]
  PName           varchar [not null]
  Category        varchar

  Note: 'Master dictionary of all items.'
}

Table Vendor {
  VID        varchar [pk]
  VendorName varchar [not null]
  VendorPrefix varchar [note: 'Vendor-specific prefix']
  Location   varchar
  Contact    varchar
  Email      varchar

  Note: 'Central directory of all suppliers.'
}

Table VendorProduct {
  VPID         varchar [pk]
  VID          varchar [not null, ref: > Vendor.VID]
  PID          varchar [not null, ref: > Product.PID]

  Note: 'Maps which vendor sells which product. Bridge between Vendor and Product.'
}

Table SKU {
  SKUID       varchar [pk]
  VPID        varchar [not null, ref: > VendorProduct.VPID, note: 'Kept directly on SKU for fast lookup']
  UnitMeasurementBuy int
  LotSizeBuy int
  CurrentBuyRate  decimal(10,2)
  UnitMeasurementSell int
  LotSizeSell int
  CurrentSellRate decimal(10,2)
  Specs       json    [note: 'Item variations e.g. size, color, grade']
  StockQty    int     [default: 0]
  Threshold   int     [note: 'Reorder level — alert when StockQty falls below this']

  Note: 'Physical stock unit in godown. One VendorProduct maps to exactly one SKU.'
}


// ══════════════════════════════════════════════
//  VENDOR OPERATIONS (PROCUREMENT)
// ══════════════════════════════════════════════

Table VendorOrder {
  VOID      varchar  [pk]
  VID       varchar  [not null, ref: > Vendor.VID]
  CreatedBy varchar  [not null, ref: > User.UID]
  OrderDate date     [not null]
  Status    varchar  [note: 'Draft / Confirmed / PartiallyReceived / Completed / Cancelled']
  TotalAmount decimal(10,2)

  Note: 'Purchase Order (PO) raised to a vendor.'
}

Table VendorOrderDetail {
  VODetailID varchar  [pk]
  VOID       varchar  [not null, ref: > VendorOrder.VOID]
  SKUID      varchar  [not null, ref: > SKU.SKUID]
  OrderedQty int      [not null]
  AgreePrice decimal(10,2) [note: 'Agreed price at time of PO']
  Amount     decimal(10,2)

  Note: 'Line items of the PO. Records what was requested before goods arrive.'
}

Table VendorInvoice {
  InvID        varchar [pk]
  VOID         varchar [not null, ref: > VendorOrder.VOID]
  InvoiceDate  date    [not null]
  VendorInvNum varchar [note: 'Vendor-side invoice reference number']
  TotalAmount  decimal(10,2)

  Note: 'Delivery document from vendor. Multiple invoices per order support partial deliveries.'
}

Table VendorInvoiceDetail {
  DetailID      varchar     [pk]
  InvID         varchar     [not null, ref: > VendorInvoice.InvID]
  SKUID         varchar     [not null, ref: > SKU.SKUID]
  OrderedQty    int
  ArrivedQty    int         [note: 'May differ from OrderedQty — tracks shortfalls']
  PurchasePrice decimal(10,2) [note: 'Price locked at time of this invoice']
  Amount        decimal(10,2)

  Note: 'Line items of a vendor invoice. Price is historical and immutable after entry.'
}

Table VendorReturn {
  VReturnID   varchar [pk]
  InvID       varchar [not null, ref: > VendorInvoice.InvID]
  InitiatedBy varchar [not null, ref: > User.UID]
  ReturnDate  date    [not null]
  Reason      varchar
  Status      varchar [note: 'Pending / Processed / Credited']

  Note: 'Records goods being sent back to a vendor. Linked to the originating invoice.'
}

Table VendorReturnDetail {
  VRDetailID   varchar     [pk]
  VReturnID    varchar     [not null, ref: > VendorReturn.VReturnID]
  SKUID        varchar     [not null, ref: > SKU.SKUID]
  ReturnQty    int         [not null]
  CreditAmount decimal(10,2)

  Note: 'Line items of a vendor return. Processing triggers a negative StockAdjustment.'
}


// ══════════════════════════════════════════════
//  CUSTOMER OPERATIONS (SALES)
// ══════════════════════════════════════════════

Table Customer {
  CID          varchar [pk]
  UID          varchar [not null, ref: > User.UID]
  CustomerName varchar [not null]
  Category     varchar [note: 'Defines default priority: High / Medium / Low']
  Location     varchar
  Pincode      int
  Contact      varchar
  Email        varchar

  Note: 'Central directory of all customers.'
}

Table CustomerOrder {
  COID      varchar [pk]
  CID       varchar [not null, ref: > Customer.CID]
  CreatedBy varchar [not null, ref: > User.UID]
  OrderDate date    [not null]
  Status    varchar [note: 'Draft / Confirmed / PartiallyFulfilled / Completed / Cancelled']
  Priority  varchar [note: 'Inherits Customer.Category by default; can be overridden. High / Medium / Low']
  TotalAmount decimal(10,2)

  Note: 'Sales Order. Priority inheritance from Customer.Category is enforced at application layer.'
}

Table CustomerOrderDetail {
  CODID     varchar [pk]
  COID      varchar [not null, ref: > CustomerOrder.COID]
  SKUID     varchar [not null, ref: > SKU.SKUID]
  Quantity  int
  Amount    decimal(10,2)
}

Table PackingSlip {
  PackSlipID  varchar [pk]
  COID        varchar [not null, ref: > CustomerOrder.COID]
  PackedBy    varchar [not null, ref: > User.UID]
  PackedDate  date    [not null]
  Status      varchar [note: 'Packed / Shipped']

  Note: 'Represents one packed batch from an order. 
         Status moves to Shipped when invoice is created.'
}

Table PackingSlipDetail {
  PSDetailID  varchar [pk]
  PackSlipID  varchar [not null, ref: > PackingSlip.PackSlipID]
  SKUID       varchar [not null, ref: > SKU.SKUID]
  PackedQty   int     [not null]

  Note: 'Line items in the packed batch. 
         PackedQty must not exceed remaining unfulfilled qty from CustomerOrderDetail.'
}

Table CustomerInvoice {
  CInvID      varchar [pk]
  PackSlipID  varchar [not null, ref: > PackingSlip.PackSlipID]
  CreatedBy   varchar [not null, ref: > User.UID]
  InvoiceDate date    [not null]
  Status      varchar [note: 'Unpaid / PartiallyPaid / Paid']
  TotalAmount decimal(10,2)

  Note: 'Bill / dispatch note. Multiple invoices per order support partial fulfillment.'
}

Table CustomerInvDetail {
  CDetailID    varchar     [pk]
  CInvID       varchar     [not null, ref: > CustomerInvoice.CInvID]
  SKUID        varchar     [not null, ref: > SKU.SKUID]
  OrderedQty   int
  DeliveredQty int         [note: 'May be less than OrderedQty for partial fulfillment']
  SalePrice    decimal(10,2) [note: 'Price locked at time of invoice']
  Amount       decimal(10,2)

  Note: 'Individual line items sold on a customer invoice.'
}

Table Payment {
  PaymentID   varchar     [pk]
  CInvID      varchar     [not null, ref: > CustomerInvoice.CInvID]
  RecordedBy  varchar     [not null, ref: > User.UID]
  PaymentDate date        [not null]
  Amount      decimal(10,2) [not null]
  Method      varchar     [note: 'Cash / UPI / Bank Transfer / Cheque']
  Reference   varchar     [note: 'UTR, cheque number, or transaction ID']
  Notes       text

  Note: 'Each row is one payment event. Multiple payments per invoice support partial settlement.'
}

Table Dispatch {
  DispatchID   varchar [pk]
  CInvID       varchar [not null, ref: > CustomerInvoice.CInvID]
  DispatchedBy varchar [not null, ref: > User.UID]
  DispatchDate date    [not null]
  Carrier      varchar
  Status       varchar [note: 'Pending / Dispatched / Delivered']

  Note: 'Records when and how goods leave the godown for a given invoice.'
}

Table CustomerReturn {
  CReturnID   varchar [pk]
  CInvID      varchar [not null, ref: > CustomerInvoice.CInvID]
  InitiatedBy varchar [not null, ref: > User.UID]
  ReturnDate  date    [not null]
  Reason      varchar
  Status      varchar [note: 'Pending / Processed / Refunded']

  Note: 'Records goods returned by a customer. Linked to originating invoice.'
}

Table CustomerReturnDetail {
  CRDetailID   varchar     [pk]
  CReturnID    varchar     [not null, ref: > CustomerReturn.CReturnID]
  SKUID        varchar     [not null, ref: > SKU.SKUID]
  ReturnQty    int         [not null]
  RefundAmount decimal(10,2)

  Note: 'Line items of a customer return. Processing triggers a positive StockAdjustment.'
}


// ══════════════════════════════════════════════
//  INVENTORY CONTROL
// ══════════════════════════════════════════════

Table StockAdjustment {
  AdjID      varchar [pk]
  SKUID      varchar [not null, ref: > SKU.SKUID]
  AdjustedBy varchar [not null, ref: > User.UID]
  AdjDate    date    [not null]
  Delta      int     [not null, note: 'Positive = stock added, Negative = stock removed']
  Reason     varchar [note: 'Damage / Write-off / Opening Stock / Manual Correction / Return']
  RefDocID   varchar [note: 'Optional FK to VendorReturn.VReturnID or CustomerReturn.CReturnID']

  Note: 'Immutable audit log for every stock change outside normal buy/sell flows.'
}
